{
  "name": "bulgarian-tax-declaration",
  "private": true,
  "scripts": {
    "test": "pnpm -r test",
    "test:core": "pnpm --filter @bg-tax/core test",
    "build": "pnpm -r build",
    "dev": "pnpm --filter @bg-tax/ui dev",
    "bundle": "pnpm --filter @bg-tax/ui exec tauri build && node scripts/copy-bundle.mjs",
    "typecheck": "pnpm --filter @bg-tax/core exec tsc -p tsconfig.json --noEmit && pnpm --filter @bg-tax/ui exec tsc -b && pnpm --filter @bg-tax/ui exec tsc -p ../../tsconfig.scripts.json --noEmit",
    "lint": "eslint . --ext .ts,.tsx",
    "lint:fix": "eslint . --ext .ts,.tsx --fix",
    "format": "node ./scripts/run-dprint.mjs fmt",
    "format:check": "node ./scripts/run-dprint.mjs check",
    "spell": "cspell '**'"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@cspell/dict-bg-bg": "^3.0.8",
    "@stylistic/eslint-plugin": "^5.9.0",
    "@typescript-eslint/eslint-plugin": "^8.56.0",
    "@typescript-eslint/parser": "^8.56.0",
    "cspell": "^8.14.0",
    "dprint": "^0.47.0",
    "eslint": "^8.57.1",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-import-newlines": "^2.0.0",
    "eslint-plugin-jest": "^29.15.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^4.6.2",
    "playwright": "^1.58.2"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  },
  "packageManager": "pnpm@10.32.1+sha512.a706938f0e89ac1456b6563eab4edf1d1faf3368d1191fc5c59790e96dc918e4456ab2e67d613de1043d2e8c81f87303e6b40d4ffeca9df15ef1ad567348f2be"
}
