{
  "version": "0.2",
  "language": "en",
  "ignorePaths": [
    "node_modules",
    "**/node_modules",
    "**/lib",
    "**/dist",
    "**/build",
    "coverage",
    "**/src-tauri/gen",
    "**/target",
    "**/*.d.ts",
    "**/*.svg",
    "**/*.xls",
    "**/*.xlsx",
    "pnpm-lock.yaml",
    "**/*.toml",
    "**/*.plist",
    "**/*.applescript",
    "samples/**",
    "templates/**",
    "**/tests/fixtures/**"
  ],
  "import": ["@cspell/dict-bg-bg/cspell-ext.json"],
  "dictionaryDefinitions": [
    {
      "name": "project-words",
      "path": "./cspell-dict.txt",
      "addWords": true
    }
  ],
  "dictionaries": ["project-words", "bg-bg"]
}
